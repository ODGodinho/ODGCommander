{
    "name": "@odg/command",
    "version": "0.0.0",
    "description": "ODGCommander used to create files based in stubs",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "homepage": "https://github.com/ODGodinho/ODGCommander",
    "repository": {
        "type": "git",
        "url": "https://github.com/ODGodinho/ODGCommander"
    },
    "bin": {
        "odg": "./odg.js"
    },
    "scripts": {
        "build": "rimraf dist/ && tsc --project ./tsconfig.build.json && tsc-alias -p tsconfig.build.json",
        "build:watch": "npm run build && (concurrently \"tsc --project ./tsconfig.build.json -w\" \"tsc-alias -p tsconfig.build.json -w\")",
        "dev": "tsx ./src/index.ts",
        "odg": "tsx ./src/index.ts",
        "start": "node ./dist/index.js",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "prepare": "husky",
        "test": "vitest run",
        "test:ci": "vitest run --passWithNoTests",
        "test:watch": "vitest --watch"
    },
    "publishConfig": {
        "access": "public"
    },
    "lint-staged": {
        "*": [
            "npm run lint:fix"
        ]
    },
    "release": {
        "branches": [
            "+([0-9])?(.{+([0-9]),x}).x",
            "main",
            "master",
            "next",
            "next-major",
            {
                "name": "beta",
                "prerelease": true
            },
            {
                "name": "alpha",
                "prerelease": true
            }
        ],
        "plugins": [
            "@semantic-release/commit-analyzer",
            "@semantic-release/release-notes-generator",
            "@semantic-release/npm",
            "@semantic-release/github"
        ]
    },
    "files": [
        "odg.js",
        "./dist/",
        "./stubs/",
        "./README.md"
    ],
    "author": "Dragons Gamers <https://www.linkedin.com/in/victor-alves-odgodinho>",
    "license": "MIT",
    "devDependencies": {
        "@odg/eslint-config": "*",
        "@odg/tsconfig": "*",
        "@types/node": ">=24",
        "@vitest/coverage-v8": "^4.0.18",
        "concurrently": "^9.2.1",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.7",
        "reflect-metadata": "^0.2.2",
        "rimraf": "*",
        "tsc-alias": "^1.8.16",
        "tsx": "^4.21.0",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.0.18"
    },
    "dependencies": {
        "@odg/chemical-x": "*",
        "@odg/exception": "*",
        "@odg/log": "^1.6.1",
        "commander": "^13.0.0"
    }
}
